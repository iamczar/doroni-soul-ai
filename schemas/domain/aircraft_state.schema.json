{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doroni.com/soul-ai/schemas/domain/aircraft_state",
  "title": "Aircraft State",
  "description": "Soul AI aircraft state domain model — current snapshot of the aircraft",
  "type": "object",
  "required": ["aircraft_id", "readiness_state"],
  "properties": {
    "aircraft_id": {
      "type": "string",
      "description": "Unique aircraft identifier"
    },
    "tail_number": {
      "type": "string",
      "description": "Aircraft registration number"
    },
    "battery_percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Battery state of charge as a percentage"
    },
    "range_estimate_nm": {
      "type": "number",
      "minimum": 0,
      "description": "Estimated range in nautical miles at current charge"
    },
    "cabin_temperature_celsius": {
      "type": "number",
      "description": "Current cabin temperature reading"
    },
    "lock_state": {
      "type": "string",
      "enum": ["locked", "unlocked", "unknown"],
      "description": "Current door lock state"
    },
    "lighting_state": {
      "type": "object",
      "properties": {
        "ambient_rgb": { "type": "string" },
        "ambient_brightness_percent": { "type": "integer" },
        "duct_rgb": { "type": "string" },
        "duct_brightness_percent": { "type": "integer" },
        "knob_lights_enabled": { "type": "boolean" }
      }
    },
    "readiness_state": {
      "type": "string",
      "enum": ["ready", "preparing", "maintenance_required", "charging", "unavailable", "unknown"],
      "description": "Overall aircraft readiness"
    },
    "active_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "caution", "warning", "critical"] },
          "message": { "type": "string" }
        }
      }
    },
    "maintenance_state": {
      "type": "object",
      "properties": {
        "next_scheduled_maintenance": { "type": "string", "format": "date" },
        "maintenance_required": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "current_location": {
      "type": "object",
      "properties": {
        "lat": { "type": "number" },
        "lon": { "type": "number" },
        "location_name": { "type": "string" },
        "last_updated": { "type": "string", "format": "date-time" }
      }
    },
    "climate_state": {
      "type": "object",
      "properties": {
        "ac_on": { "type": "boolean" },
        "target_temperature_celsius": { "type": "number" },
        "fan_speed_percent": { "type": "integer" }
      }
    },
    "state_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this state snapshot was last updated"
    }
  }
}
