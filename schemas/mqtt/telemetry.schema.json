{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doroni.com/soul-ai/schemas/mqtt/telemetry",
  "title": "Telemetry MQTT Messages",
  "description": "JSON schemas for Soul AI telemetry ingestion MQTT messages",
  "definitions": {
    "envelope": {
      "type": "object",
      "required": ["source", "target", "message_id", "correlation_id", "timestamp", "risk_level", "payload"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string", "enum": ["cloud"] },
        "message_id": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time" },
        "risk_level": { "type": "integer", "minimum": 0, "maximum": 5 },
        "payload": { "type": "object" }
      }
    },
    "telemetry_session_start": {
      "allOf": [
        { "$ref": "#/definitions/envelope" },
        {
          "properties": {
            "message_id": { "const": "telemetry_session_start" },
            "risk_level": { "const": 0 },
            "payload": {
              "type": "object",
              "required": ["session_id", "source", "user_id", "aircraft_id", "simulator_or_real"],
              "properties": {
                "session_id": { "type": "string" },
                "source": {
                  "type": "string",
                  "enum": ["msfs", "xplane", "embention", "real"],
                  "description": "Telemetry source system"
                },
                "user_id": { "type": "string" },
                "aircraft_id": { "type": "string" },
                "simulator_or_real": {
                  "type": "string",
                  "enum": ["simulator", "real"]
                }
              }
            }
          }
        }
      ]
    },
    "telemetry_session_stop": {
      "allOf": [
        { "$ref": "#/definitions/envelope" },
        {
          "properties": {
            "message_id": { "const": "telemetry_session_stop" },
            "risk_level": { "const": 0 },
            "payload": {
              "type": "object",
              "required": ["session_id"],
              "properties": {
                "session_id": { "type": "string" }
              }
            }
          }
        }
      ]
    },
    "telemetry_frame": {
      "allOf": [
        { "$ref": "#/definitions/envelope" },
        {
          "properties": {
            "message_id": { "const": "telemetry_frame" },
            "risk_level": { "const": 0 },
            "payload": {
              "type": "object",
              "required": ["session_id", "timestamp", "lat", "lon", "altitude_ft", "ground_speed_kts", "heading_deg"],
              "properties": {
                "session_id": { "type": "string" },
                "timestamp": { "type": "string", "format": "date-time" },
                "lat": { "type": "number", "minimum": -90, "maximum": 90 },
                "lon": { "type": "number", "minimum": -180, "maximum": 180 },
                "altitude_ft": { "type": "number" },
                "ground_speed_kts": { "type": "number", "minimum": 0 },
                "pitch_deg": { "type": "number", "minimum": -90, "maximum": 90 },
                "roll_deg": { "type": "number", "minimum": -180, "maximum": 180 },
                "yaw_deg": { "type": "number", "minimum": -180, "maximum": 180 },
                "heading_deg": { "type": "number", "minimum": 0, "maximum": 360 },
                "flight_phase": {
                  "type": "string",
                  "enum": ["ground", "departure", "climb", "cruise", "descent", "approach", "landing"]
                }
              }
            }
          }
        }
      ]
    },
    "telemetry_event": {
      "allOf": [
        { "$ref": "#/definitions/envelope" },
        {
          "properties": {
            "message_id": { "const": "telemetry_event" },
            "risk_level": { "const": 0 },
            "payload": {
              "type": "object",
              "required": ["session_id", "timestamp", "event_type"],
              "properties": {
                "session_id": { "type": "string" },
                "timestamp": { "type": "string", "format": "date-time" },
                "event_type": {
                  "type": "string",
                  "enum": [
                    "route_deviation",
                    "altitude_deviation",
                    "airspeed_deviation",
                    "overcorrection",
                    "warning_triggered",
                    "phase_change",
                    "joystick_spike"
                  ]
                },
                "details": { "type": "object" }
              }
            }
          }
        }
      ]
    },
    "telemetry_get_summary": {
      "allOf": [
        { "$ref": "#/definitions/envelope" },
        {
          "properties": {
            "message_id": { "const": "telemetry_get_summary" },
            "risk_level": { "const": 0 },
            "payload": {
              "type": "object",
              "required": ["session_id"],
              "properties": {
                "session_id": { "type": "string" }
              }
            }
          }
        }
      ]
    }
  }
}
